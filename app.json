{
  "expo": {
    "name": "SAVR",
    "slug": "savr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.savr.app"
    },
    "android": {
      "package": "com.savr.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      }
    },
    "scheme": "savr",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "resizeMode": "contain"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
